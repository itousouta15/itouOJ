generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String               @id @default(cuid())
  username     String               @unique
  passwordHash String? // null = Google 帳號，沒有本地密碼
  googleId     String?              @unique // Google 帳號的 sub
  discordId    String?              @unique // Discord 帳號的 id
  email        String? // 目前只有 Google / Discord 登入會帶入
  role         String               @default("USER") // USER | ADMIN
  displayName  String? // 顯示名稱（未設定時顯示 username）
  bio          String? // 自我介紹
  createdAt    DateTime             @default(now())
  submissions  Submission[]
  courses      CourseMember[]
  contests     ContestParticipant[]
  problemProposals ProblemProposal[]
}

model Problem {
  id              Int              @id @default(autoincrement())
  title           String
  statement       String // Markdown，支援數學式
  difficulty      String           @default("medium") // easy | medium | hard
  timeLimitMs     Int              @default(1000)
  memoryLimitMb   Int              @default(256)
  isPublic        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  testCases       TestCase[]
  submissions     Submission[]
  courseProblems  CourseProblem[]
  contestProblems ContestProblem[]
}

// 題單型課程：一組題目 + 說明，使用者加入後追蹤解題進度
model Course {
  id          Int             @id @default(autoincrement())
  title       String
  description String          @default("")
  isPublic    Boolean         @default(true)
  joinCode    String? // 加入代碼；null = 開放任何人加入
  createdAt   DateTime        @default(now())
  problems    CourseProblem[]
  members     CourseMember[]
}

model CourseProblem {
  id        Int     @id @default(autoincrement())
  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  problemId Int
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@unique([courseId, problemId])
}

model CourseMember {
  id       Int      @id @default(autoincrement())
  courseId Int
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([courseId, userId])
}

// 有起訖時間的小型比賽：只有比賽期間的提交才計分，罰時排名 + 賽末凍結榜
model Contest {
  id            Int                  @id @default(autoincrement())
  title         String
  description   String               @default("")
  startTime     DateTime
  endTime       DateTime
  freezeMinutes Int                  @default(0) // 0 = 不凍結
  isPublic      Boolean              @default(true)
  joinCode      String? // 加入代碼；null = 開放任何人加入
  revealedAt    DateTime? // 管理員手動「公開最終成績」的時間；null = 尚未公開
  createdAt     DateTime             @default(now())
  problems      ContestProblem[]
  participants  ContestParticipant[]
  submissions   Submission[]
}

model ContestProblem {
  id        Int     @id @default(autoincrement())
  contestId Int
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId Int
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  label     String // "A" "B" "C" ...
  order     Int     @default(0)

  @@unique([contestId, problemId])
  @@unique([contestId, label])
}

model ContestParticipant {
  id        Int      @id @default(autoincrement())
  contestId Int
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([contestId, userId])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String // Markdown
  isPinned  Boolean  @default(false) // 置頂公告固定顯示在最上面
  createdAt DateTime @default(now())
}

// 使用者投稿的出題申請；審核通過後才會建立成正式的 Problem
model ProblemProposal {
  id                Int                @id @default(autoincrement())
  title             String
  statement         String
  difficulty        String             @default("medium")
  timeLimitMs       Int                @default(1000)
  memoryLimitMb     Int                @default(256)
  status            String             @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote        String? // 管理員退回原因；核准後清空
  authorId          String
  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  approvedProblemId Int? // 核准後建立的正式 Problem id
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  testCases         ProposalTestCase[]
}

model ProposalTestCase {
  id         Int             @id @default(autoincrement())
  proposalId Int
  proposal   ProblemProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  input      String
  output     String
  isSample   Boolean         @default(false)
  order      Int             @default(0)
}

model TestCase {
  id        Int     @id @default(autoincrement())
  problemId Int
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input     String
  output    String
  isSample  Boolean @default(false) // 範例測資會顯示在題目頁
  order     Int     @default(0)
}

model Submission {
  id           Int          @id @default(autoincrement())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    Int
  problem      Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  contestId    Int? // 有值 = 這是比賽期間的提交，計入該比賽罰時排名
  contest      Contest?     @relation(fields: [contestId], references: [id], onDelete: SetNull)
  language     String // cpp | c | python | java | javascript
  code         String
  status       String       @default("PENDING") // PENDING JUDGING AC WA TLE MLE RE CE IE
  compileError String?
  timeMs       Int? // 所有測資的最大值
  memoryKb     Int?
  createdAt    DateTime     @default(now())
  results      TestResult[]
}

model TestResult {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  verdict      String // AC WA TLE MLE RE
  timeMs       Int?
  memoryKb     Int?
}
