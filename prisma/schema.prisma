generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String? // null = Google 帳號，沒有本地密碼
  googleId     String?        @unique // Google 帳號的 sub
  email        String? // 目前只有 Google 登入會帶入
  role         String         @default("USER") // USER | ADMIN
  displayName  String? // 顯示名稱（未設定時顯示 username）
  bio          String? // 自我介紹
  createdAt    DateTime       @default(now())
  submissions  Submission[]
  courses      CourseMember[]
}

model Problem {
  id             Int             @id @default(autoincrement())
  title          String
  statement      String // Markdown，支援數學式
  difficulty     String          @default("medium") // easy | medium | hard
  timeLimitMs    Int             @default(1000)
  memoryLimitMb  Int             @default(256)
  isPublic       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  testCases      TestCase[]
  submissions    Submission[]
  courseProblems CourseProblem[]
}

// 題單型課程：一組題目 + 說明，使用者加入後追蹤解題進度
model Course {
  id          Int             @id @default(autoincrement())
  title       String
  description String          @default("")
  isPublic    Boolean         @default(true)
  joinCode    String? // 加入代碼；null = 開放任何人加入
  createdAt   DateTime        @default(now())
  problems    CourseProblem[]
  members     CourseMember[]
}

model CourseProblem {
  id        Int     @id @default(autoincrement())
  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  problemId Int
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@unique([courseId, problemId])
}

model CourseMember {
  id       Int      @id @default(autoincrement())
  courseId Int
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([courseId, userId])
}

model TestCase {
  id        Int     @id @default(autoincrement())
  problemId Int
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input     String
  output    String
  isSample  Boolean @default(false) // 範例測資會顯示在題目頁
  order     Int     @default(0)
}

model Submission {
  id           Int          @id @default(autoincrement())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    Int
  problem      Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language     String // cpp | c | python | java | javascript
  code         String
  status       String       @default("PENDING") // PENDING JUDGING AC WA TLE MLE RE CE IE
  compileError String?
  timeMs       Int? // 所有測資的最大值
  memoryKb     Int?
  createdAt    DateTime     @default(now())
  results      TestResult[]
}

model TestResult {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  verdict      String // AC WA TLE MLE RE
  timeMs       Int?
  memoryKb     Int?
}
